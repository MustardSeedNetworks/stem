{
  "name": "stem-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Stem WebUI - Network Performance Testing - Mustard Seed Networks",
  "engines": {
    "node": "26.4.0",
    "npm": "11.18.0"
  },
  "scripts": {
    "dev": "node --disable-warning=DEP0205 ./node_modules/vite/bin/vite.js",
    "gen-types": "node scripts/gen-types.mjs",
    "build": "tsgo --build && node --disable-warning=DEP0205 ./node_modules/vite/bin/vite.js build",
    "build:analyze": "tsgo --build && ANALYZE=true node --disable-warning=DEP0205 ./node_modules/vite/bin/vite.js build",
    "typecheck": "tsgo --build --noEmit",
    "preview": "node --disable-warning=DEP0205 ./node_modules/vite/bin/vite.js preview",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "node --disable-warning=DEP0205 ./node_modules/vitest/vitest.mjs run --reporter=verbose --passWithNoTests",
    "test:watch": "node --disable-warning=DEP0205 ./node_modules/vitest/vitest.mjs --reporter=dot",
    "test:coverage": "node --disable-warning=DEP0205 ./node_modules/vitest/vitest.mjs run --coverage --reporter=verbose",
    "test:e2e": "NO_COLOR= node --disable-warning=DEP0205 ./node_modules/playwright/cli.js test --reporter=list",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@hookform/resolvers": "5.4.0",
    "@tailwindcss/postcss": "4.3.2",
    "@tanstack/react-query": "5.101.2",
    "cmdk": "1.1.1",
    "i18next": "26.3.4",
    "i18next-browser-languagedetector": "8.2.1",
    "immer": "11.1.11",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-i18next": "17.0.8",
    "react-router-dom": "7.18.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "valibot": "1.4.2",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@chromatic-com/storybook": "5.2.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "jsdom": "29.1.1",
    "json-schema-to-typescript": "15.0.4",
    "playwright": "1.61.1",
    "postcss": "8.5.16",
    "rollup-plugin-visualizer": "7.0.1",
    "storybook": "10.4.6",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "@typescript/native-preview": "7.0.0-dev.20260706.1"
  },
  "packageManager": "npm@11.18.0"
}
