{
  "name": "stem",
  "version": "0.1.0",
  "private": true,
  "description": "The Stem - Network Performance Testing - Mustard Seed Networks",
  "type": "module",
  "engines": {
    "node": "26.3.0",
    "npm": "11.17.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "cd ui && npm run dev",
    "build": "cd ui && npm run build",
    "preview": "cd ui && npm run preview",
    "lint": "cd ui && npm run lint",
    "lint:fix": "cd ui && npm run lint:fix",
    "format": "cd ui && npm run format",
    "test": "cd ui && npm run test",
    "test:watch": "cd ui && npm run test:watch",
    "test:coverage": "cd ui && npm run test:coverage",
    "test:e2e": "cd ui && npm run test:e2e",
    "storybook": "cd ui && npm run storybook",
    "build-storybook": "cd ui && npm run build-storybook"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "@typescript/native-preview": "7.0.0-dev.20260615.1"
  },
  "lint-staged": {
    "ui/src/**/*.{ts,tsx}": "cd ui && npx biome check --write",
    "*.{json,md,yml,yaml}": "cd ui && npx biome format --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "npm@11.17.0"
}
